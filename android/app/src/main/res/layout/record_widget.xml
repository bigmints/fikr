<?xml version="1.0" encoding="utf-8"?>
<!--
  Home-screen widget layout for Fikr.
  A dark rounded card with a mic icon and two text lines.
  Background uses a shape drawable so it works on all Android versions.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Mic icon -->
    <ImageView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_mic_widget"
        android:contentDescription="Record" />

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Fikr"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium" />

    <!-- Last note title / prompt text -->
    <TextView
        android:id="@+id/widget_last_note"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="Tap to record a thought"
        android:textColor="#B0FFFFFF"
        android:textSize="11sp" />

</LinearLayout>
